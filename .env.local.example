# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# 4-6 digit PIN required to access the app
APP_PIN=1234

# Secret used to sign session cookies (any random string, 32+ chars)
SESSION_SECRET=change-me-to-a-long-random-string

# Default currency code (INR, USD, EUR, GBP). Can be overridden via /settings.
CURRENCY=INR
